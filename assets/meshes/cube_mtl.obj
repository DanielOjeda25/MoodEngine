# Cubo simple para validar el path Assimp .obj + .mtl (Hito 35 C).
# Material referenciado en cube_mtl.mtl con textura albedo via map_Kd.
# 8 vertices, 12 triangulos.

mtllib cube_mtl.mtl

# vertices
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# UVs
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

usemtl Brick

# back (z=-0.5)
f 1/1 3/3 2/2
f 1/1 4/4 3/3
# front (z=+0.5)
f 5/1 6/2 7/3
f 5/1 7/3 8/4
# left (x=-0.5)
f 1/1 5/2 8/3
f 1/1 8/3 4/4
# right (x=+0.5)
f 2/1 3/4 7/3
f 2/1 7/3 6/2
# top (y=+0.5)
f 4/1 8/2 7/3
f 4/1 7/3 3/4
# bottom (y=-0.5)
f 1/1 2/2 6/3
f 1/1 6/3 5/4
