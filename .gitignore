# Build
build/
out/
cmake-build-*/

# IDEs
.vs/
.vscode/
.idea/
*.user
*.suo
*.sln.docstates
CMakeUserPresets.json

# Compilados
*.obj
*.o
*.exe
*.dll
*.lib
*.pdb
*.ilk
*.exp

# Excepciones: Wavefront OBJ de assets (misma extension que objetos MSVC
# pero son modelos 3D que si queremos versionar).
!assets/meshes/*.obj

# F2H6: cache de LODs generados al cargar meshes. Lateral al formato
# .moodmap (borrarlo no rompe nada — solo fuerza re-generacion al
# proximo arranque). No commiteable porque depende del meshoptimizer
# instalado del dev y de los mtimes de los sources.
assets/.cache/

# F2H49: FBX de personajes (Mixamo). Pesan >100MB cuando vienen con
# texturas embedded y GitHub bloquea archivos individuales >100MB.
# Cada dev baja los suyos siguiendo assets/characters/README.md.
# README, configs .json, .moodprefab y demas si se commitean.
assets/characters/**/*.fbx
assets/characters/**/*.FBX

# Logs
logs/
*.log

# SO
.DS_Store
Thumbs.db

# Archivos temporales
*.swp
*.bak
*~

# Estado de runtime
imgui.ini
imgui_layout_*.ini
.mood/

# Python (bytecode generado al importar tools/*.py)
__pycache__/
*.pyc

# Herramientas de agentes de codigo
.claude/
